# NEXUS web (apps/nexus/apps/web) — must be set at BUILD time on Vercel.
# Point this at the deployed Cloudflare Worker URL for the NEXUS API.
# When unset, the dashboard silently falls back to http://localhost:8787
# and every API call fails in production.
NEXT_PUBLIC_API_URL=

# Redis (optional)
REDIS_URL=

# Mastra (optional — defaults to file:.mastra/storage.db)
MASTRA_STORAGE_URL=file:.mastra/storage.db
# Postgres direct URL for Mastra + memory (Supabase database connection string)
DATABASE_URL=

NODE_ENV=development
