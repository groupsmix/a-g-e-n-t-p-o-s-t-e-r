# Anthropic
ANTHROPIC_API_KEY=

# OpenAI (fallback + Whisper)
OPENAI_API_KEY=

# CosmicJS
COSMIC_BUCKET_SLUG=
COSMIC_READ_KEY=
COSMIC_WRITE_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Replicate
REPLICATE_API_TOKEN=

# FAL.ai (optional)
FAL_API_KEY=

# TikTok
TIKTOK_ACCESS_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Instagram / Facebook
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
FACEBOOK_PAGE_ID=

# YouTube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Twitter / X
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Optional social
PINTEREST_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=

# Amazon Associates
AMAZON_ASSOCIATE_TAG=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=

# Gumroad (optional)
GUMROAD_ACCESS_TOKEN=

# Analytics (optional)
GOOGLE_ANALYTICS_ID=

# Cloudflare — used by `wrangler` for Workers + Pages deploys.
CLOUDFLARE_EMAIL=
CLOUDFLARE_API_KEY=

# NEXUS web (apps/nexus/apps/web) — must be set at BUILD time before
# `pnpm pages:build`. The `pages:build` script already defaults this to the
# live NEXUS API URL, so you only need to set it here for local builds that
# target a different API. When unset and not injected by the build script,
# the dashboard silently falls back to http://localhost:8787.
NEXT_PUBLIC_API_URL=

# Redis (optional)
REDIS_URL=

# Mastra (optional — defaults to file:.mastra/storage.db)
MASTRA_STORAGE_URL=file:.mastra/storage.db
# Postgres direct URL for Mastra + memory (optional — leave blank if you're
# running pure Cloudflare D1).
DATABASE_URL=

NODE_ENV=development
