{
  "name": "posteragent",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "generate": "turbo generate",
    "publish:all": "turbo publish:all",
    "factory:run": "turbo factory:run",
    "check-env": "tsx scripts/check-env.ts",
    "preflight": "node scripts/preflight.mjs",
    "preflight:fast": "node scripts/preflight.mjs --skip-build --skip-lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.5",
    "eslint": "^9",
    "prettier": "^3.8.4",
    "tsx": "^4.7.0",
    "turbo": "^2.9.17",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.61.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "apps/nexus/apps/*",
    "apps/nexus/packages/*"
  ]
}
