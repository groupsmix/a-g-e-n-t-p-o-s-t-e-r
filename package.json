{
  "name": "posteragent",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "generate": "turbo generate",
    "publish:all": "turbo publish:all",
    "factory:run": "turbo factory:run",
    "check-env": "tsx scripts/check-env.ts",
    "postinstall": "node -e \"const fs=require('fs'); if(fs.existsSync('apps/nexus')){require('child_process').execSync('cd apps/nexus && pnpm install --prefer-offline', {stdio:'inherit'})}\""
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.5",
    "prettier": "^3.2.4",
    "tsx": "^4.7.0",
    "turbo": "^2.9.16",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "apps/nexus/apps/*",
    "apps/nexus/packages/*"
  ]
}
