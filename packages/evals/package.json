{
  "name": "@posteragent/evals",
  "version": "0.1.0",
  "private": true,
  "description": "TASK-1100 — Per-agent evaluation framework. Scenario-driven, scored, runnable in CI.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": { "posteragent-evals": "./bin/run.mjs" },
