{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["check-env"]
    },
    "check-env": {
      "cache": false
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "generate": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "publish:all": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "factory:run": {
      "dependsOn": ["^build"],
      "cache": false
    }
  }
}
