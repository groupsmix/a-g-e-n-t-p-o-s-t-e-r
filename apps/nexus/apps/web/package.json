{
  "name": "@nexus/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "pages:build": "pnpm turbo build --filter=@nexus/nexus-api --filter=@posteragent/ui && NEXT_PUBLIC_BUILD_SHA=${CF_PAGES_COMMIT_SHA:-$(git rev-parse HEAD 2>/dev/null || echo dev)} NEXT_PUBLIC_BUILD_TIME=$(date -u +%Y-%m-%dT%H:%M:%SZ) NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL:-https://nexus-api.simohamed.workers.dev} next-on-pages",
    "pages:deploy": "wrangler pages deploy .vercel/output/static --project-name nexus-web --branch main --commit-dirty=true",
    "pages:ship": "pnpm pages:build && pnpm pages:deploy"
  },
  "dependencies": {
    "@posteragent/types": "workspace:*",
    "@posteragent/ui": "workspace:*",
    "@radix-ui/react-slot": "^1.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "hono": "^4.12.26",
    "lucide-react": "^0.312.0",
    "next": "14.2.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@cloudflare/workers-types": "^4.20260619.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "@nexus/nexus-api": "workspace:*"
  }
}