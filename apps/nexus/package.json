{
  "name": "nexus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=@nexus/*",
    "lint": "turbo lint --filter=@nexus/*",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo clean && rm -rf node_modules",
    "typecheck": "turbo typecheck --filter=@nexus/*",
    "test": "turbo test --filter=@nexus/*",
    "db:migrate": "wrangler d1 migrations apply nexus-db --local"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.4",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "nanoid": "^3.3.11"
  }
}
