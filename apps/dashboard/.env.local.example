# apps/dashboard env vars.
# Copy this file to apps/dashboard/.env.local and fill in real values.
# .env.local is already gitignored at the repo root.

# Supabase — required by /api/stats.
# Project URL: https://app.supabase.com -> project -> Project Settings -> API
SUPABASE_URL=
# Service role key (server-only secret, never expose to the browser):
SUPABASE_SERVICE_ROLE_KEY=

# GitHub — required by /api/trigger (the "Generate now" button).
# PAT with `repo` + `workflow` scopes. Create at
# https://github.com/settings/tokens?type=beta
GITHUB_TOKEN=
# Repo that owns the workflow files. Default in code is
# `groupsmix/a-g-e-n-t-p-o-s-t-e-r` so you can leave this blank if that's
# correct.
GITHUB_REPO=groupsmix/a-g-e-n-t-p-o-s-t-e-r
# Branch the workflow_dispatch should target. Defaults to `main`.
GITHUB_REF=main
