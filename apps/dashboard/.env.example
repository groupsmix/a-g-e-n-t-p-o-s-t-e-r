# Brain Cockpit env (apps/dashboard)
#
# This dashboard is the brain-layer cockpit (memory, identity,
# proactivity, journals). It is NOT the money/ops dashboard — that lives
# at apps/nexus/apps/web. See docs/ADR-001-canonical-dashboard.md.
#
# All vars here are OPTIONAL. The cockpit boots and renders without any
# of them set.

# Public URL of the deployed NEXUS web UI. The cockpit home shows an
# "Open NEXUS" link pointing here. If unset, the link falls back to "/".
NEXT_PUBLIC_NEXUS_WEB_URL=
